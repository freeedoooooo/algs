# 电脑名称
# 可留空，留空会自动使用 Windows 电脑名
computer_name=

# 雷电安装目录
# 可留空，留空会自动查找
ldplayer_path=D:\leidian\LDPlayer64

# 期望健康数量
# 低于这个值会告警
expected_healthy_devices=27

# 是否开启邮件告警
# true=开启  false=关闭
mail_enabled=true

# 收件邮箱
# 多个邮箱用 ; 分隔
mail_to=195836303@qq.com;3198127828@qq.com

# 邮件冷却时间（分钟）
# 冷却期内不会重复发相同告警
alert_cooldown_minutes=60

