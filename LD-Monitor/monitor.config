# ==============================
# 这台电脑的名字
# 会显示在日志和告警邮件里，方便你区分是哪台电脑发出的提醒
# 例子：机房A-01、宿舍电脑、工作室3号机
# 不填时，会自动使用 Windows 电脑名
# ==============================
computer_name=HU办公笔记本

# ==============================
# 雷电模拟器安装目录
# 可以留空：
# 留空后程序会自动尝试常见安装目录和注册表路径
# 如果你知道准确路径，也可以直接填上
# ==============================
ldplayer_path=D:\leidian\LDPlayer64

# ==============================
# 正常情况下，这台电脑应该有多少个健康运行的模拟器
# 如果健康数量低于这个值，会记错误日志，并按规则发送告警邮件
# ==============================
expected_healthy_devices=27

# ==============================
# 是否开启邮件告警
# true = 开启
# false = 关闭
# ==============================
mail_enabled=true

# ==============================
# 告警发给谁
# 多个邮箱请用英文分号 ; 隔开
# 例子：aaa@qq.com;bbb@qq.com
# ==============================
mail_to=195836303@qq.com

# ==============================
# 告警邮件冷却时间，单位：分钟
# 作用：避免短时间内反复发很多封重复邮件
# 例子：60 表示 60 分钟内最多发一次同类告警
# ==============================
alert_cooldown_minutes=60
