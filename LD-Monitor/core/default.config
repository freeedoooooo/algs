# 日志
log_directory=.\log
log_file_name=monitor.log
log_max_size_mb=50
log_retention_days=7
window_clear_interval_seconds=600

# 自动发现
registry_roots=HKCU:\Software\leidian;HKLM:\Software\leidian;HKLM:\Software\WOW6432Node\leidian;HKCU:\Software\ChangZhi2;HKLM:\Software\ChangZhi2;HKLM:\Software\WOW6432Node\ChangZhi2
registry_value_names=InstallDir;InstallPath;Path;Dir;LdPlayerPath

# 检查超时
external_command_timeout_seconds=20
adb_devices_timeout_seconds=10
adb_shell_timeout_seconds=15
boot_check_attempts=3
boot_check_delay_seconds=1

# 定时与运行状态
schedule_interval_seconds=30
runner_pid_file=.\runtime\runner.pid
alert_state_file=.\runtime\alert.state.json

