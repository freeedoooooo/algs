# idc-test-c1 environment variables
# Rule:
# 1. Shared infrastructure config uses one common set of variables.
# 2. Only service-private config uses the C1_<SERVICE>_* prefix.

# ----------------------------------------
# Common deploy config
# ----------------------------------------
C1_ENV=idc-test-c1
C1_VERSION=idc-test-c1_latest

# ----------------------------------------
# Shared database config
# Keep database config to 4 variables only.
# Service-specific JDBC behavior stays in each service YAML.
# ----------------------------------------
C1_DB_DRIVER=com.mysql.cj.jdbc.Driver
C1_DB_URL=jdbc:mysql://10.0.6.161:3306/dib_report_copilot?characterEncoding=utf8&serverTimezone=Asia/Shanghai&rewriteBatchedStatements=true&useSSL=false&zeroDateTimeBehavior=convertToNull
C1_DB_USERNAME=root
C1_DB_PASSWORD=Dib12345*

# ----------------------------------------
# Shared Redis config
# ----------------------------------------
C1_REDIS_HOST=10.0.6.163
C1_REDIS_PORT=6379
C1_REDIS_DATABASE=0
C1_REDIS_PASSWORD=dibredis

# ----------------------------------------
# Shared Nacos config
# ----------------------------------------
C1_NACOS_SERVER_ADDR=http://nacos:8848
C1_NACOS_NAMESPACE=dev-c1
C1_NACOS_USERNAME=c1
C1_NACOS_PASSWORD=c1@2025

# ----------------------------------------
# Gateway private config
# ----------------------------------------
C1_GATEWAY_OAUTH_CLIENT_HOST=http://10.0.5.70:8090
C1_GATEWAY_OAUTH_SERVER_HOST=http://10.0.5.70:9090
C1_GATEWAY_OAUTH_SERVER_HOST_INNER=http://10.0.5.70:9090

# ----------------------------------------
# MDM private config
# ----------------------------------------
C1_MDM_MINIO_ENDPOINT=http://10.0.6.163:9000
C1_MDM_MINIO_ACCESS_KEY=minioadmin
C1_MDM_MINIO_SECRET_KEY=minioadmin
C1_MDM_MINIO_BUCKET_NAME=c1-bucket


# ----------------------------------------
# EXTRACT private config
# ----------------------------------------
C1_EXTRACT_OCR_SERVER=http://192.168.10.91:8089/


# ----------------------------------------
# REPORT private config
# ----------------------------------------
#C1_REPORT_AUTO_GENERATE_ENABLED=true
#C1_REPORT_TYC_TOKEN=e04e6485-e579-4cfa-866d-468cba3cf28a
#C1_REPORT_TYC_PYTHON_API=http://10.0.3.126:9310/api


# ----------------------------------------
# DATA private config
# ----------------------------------------
#C1_DATA_DI_ENABLED=true


# ----------------------------------------
# RULE private config
# ----------------------------------------
#C1_RULE_BIZ_CALC_ENABLED=true
#C1_RULE_TASK_CREATE_ENABLED=true
#C1_RULE_FRAME_CALC_ENABLED=false
#C1_RULE_NODE_CODE_REFRESH_ENABLED=true
#C1_RULE_VALUE_GC_ENABLED=true
#C1_RULE_CRON_REFRESH_ENABLED=false
#C1_RULE_TASK_MONITOR_ENABLED=true


# ----------------------------------------
# DG private config
