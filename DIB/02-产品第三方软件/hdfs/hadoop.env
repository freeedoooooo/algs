# ==========================================
# 核心配置 (CORE_CONF)
# ==========================================

# 1. 定义 HDFS 的默认访问地址
# 格式为 hdfs://<NameNode容器名>:<RPC端口>
# 这是客户端连接 HDFS 的入口地址
CORE_CONF_fs_defaultFS=hdfs://namenode:9000

# 2. 设置 Hadoop HTTP 服务的静态用户
# 容器内默认用户通常是 root，这里显式指定以避免 Web UI 或 HTTP 请求时的权限错误
CORE_CONF_hadoop_http_staticuser_user=root

# 3. 配置代理用户 (Proxy User) - Hue 相关
# 允许 Hue 服务（或其他工具）以代理身份访问 HDFS
# 下面的配置允许来自任意主机 (*) 的连接
CORE_CONF_hadoop_proxyuser_hue_hosts=*

# 4. 配置代理用户组
# 允许任意用户组 (*) 通过 Hue 代理访问
CORE_CONF_hadoop_proxyuser_hue_groups=*

# ==========================================
# HDFS 专用配置 (HDFS_CONF)
# ==========================================

# 5. 设置数据块副本数量
# 因为你只有一个 DataNode，必须设置为 1，否则上传文件会一直处于 "Pending" 状态
HDFS_CONF_dfs_replication=1

# 6. 禁用权限检查
# 设置为 false 后，任何用户都可以读写文件，非常适合开发和测试环境
HDFS_CONF_dfs_permissions_enabled=false

# 7. 禁用节点注册时的主机名/IP 检查
# 这是一个非常实用的配置。在 Docker 环境中，容器的主机名解析经常会导致 DataNode 无法向 NameNode 注册。
# 设置为 false 可以忽略这些检查，让 DataNode 顺利上线。
HDFS_CONF_dfs_namenode_datanode_registration_ip___hostname___check=false


# 强制 DataNode 使用宿主机 IP 注册
HDFS_CONF_dfs_datanode_use_datanode_hostname=false
# 替换为你的宿主机 IP
HDFS_CONF_dfs_datanode_hostname=10.0.5.70
HDFS_CONF_dfs_datanode_address=0.0.0.0:9866
HDFS_CONF_dfs_datanode_http_address=0.0.0.0:9864