# Paths
ldplayer_path=D:\leidian\LDPlayer64
common_ldplayer_dirs=D:\leidian\LDPlayer64;D:\leidian\LDPlayer9;D:\leidian;C:\leidian\LDPlayer64;C:\leidian\LDPlayer9;C:\leidian;C:\Program Files\LDPlayer\LDPlayer9;C:\Program Files\LDPlayer;C:\Program Files\dnplayerext2;D:\LDPlayer;C:\LDPlayer
log_directory=.\log
log_file_name=monitor.log

# Discovery
registry_roots=HKCU:\Software\leidian;HKLM:\Software\leidian;HKLM:\Software\WOW6432Node\leidian;HKCU:\Software\ChangZhi2;HKLM:\Software\ChangZhi2;HKLM:\Software\WOW6432Node\ChangZhi2
registry_value_names=InstallDir;InstallPath;Path;Dir;LdPlayerPath

# Health check
external_command_timeout_seconds=20
adb_devices_timeout_seconds=10
adb_shell_timeout_seconds=15
boot_check_attempts=3
boot_check_delay_seconds=1

# Runner
schedule_interval_seconds=10
runner_pid_file=.\monitor.pid

# Log policy
log_max_size_mb=50
log_retention_days=7
window_clear_interval_seconds=3600
